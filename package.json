{
  "name": "pretty-long",
  "description": "Pretty Long News media app.",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/bi-kash/PrettyLong"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next build && next export -o ./dist",
    "strapi": "cd ../ya-strapi && yarn develop",
    "format": "prettier --write .",
    "prepare": "husky install",
    "check-format": "prettier --check .",
    "check-lint": "eslint . --ext tsx --ext js",
    "check-all": "npm run check-format && npm run check-lint",
    "lint": "next lint",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@chakra-ui/react": "^1.8.8",
    "@emotion/react": "^11.9.0",
    "@emotion/styled": "^11.8.1",
    "@fontsource/inter": "^5.2.8",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bad-words": "^3.0.4",
    "boring-avatars": "^1.6.3",
    "cookie": "^1.1.1",
    "date-fns": "^2.28.0",
    "framer-motion": "^6.3.1",
    "mongoose": "^6.3.1",
    "next": "16.1.4",
    "next-auth": "^4.3.3",
    "next-pwa": "^5.5.1",
    "nextjs-redirect": "^6.0.0",
    "nprogress": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intersection-observer": "^8.34.0",
    "react-schemaorg": "^2.0.0",
    "react-share": "^4.4.0",
    "reading-time": "^1.5.0",
    "remark": "^14.0.2",
    "remark-gfm": "^3.0.1",
    "remark-html": "^15.0.1",
    "sass": "^1.50.1",
    "washyourmouthoutwithsoap": "^1.0.2"
  },
  "devDependencies": {
    "eslint": "^8.13.0",
    "eslint-config-next": "^12.1.5",
    "eslint-plugin-react": "^7.29.4",
    "husky": "^7.0.4",
    "prettier": "^2.6.2",
    "sharp": "^0.33.0",
    "ssri": "^9.0.0",
    "yaml-loader": "^0.7.0"
  }
}